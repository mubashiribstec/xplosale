generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  USER
  EMPLOYER
  ADMIN
  EMPLOYER_RECRUITER
  EMPLOYER_HIRING_MANAGER
  EMPLOYER_INTERVIEWER
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  REJECTED
  EXPIRED
  SOLD
}

enum PropertyType {
  HOUSE
  APARTMENT
  PLOT
  COMMERCIAL
  OTHER
}

enum EscrowStatus {
  HELD
  RELEASED
  REFUNDED
  DISPUTED
}

enum AgentTier {
  NONE
  BASIC
  PRO
}

enum JobStatus {
  DRAFT
  ACTIVE
  CLOSED
  EXPIRED
}

enum RemoteType {
  ONSITE
  HYBRID
  REMOTE
}

enum ApplicationStatus {
  APPLIED
  REVIEWED
  SHORTLISTED
  REJECTED
  HIRED
}

enum ConnectionStatus {
  PENDING
  ACCEPTED
  REJECTED
  BLOCKED
}

enum IdentityDocType {
  CNIC
  PASSPORT
}

enum PartnerType {
  INDIVIDUAL
  BUSINESS
  AGENCY
}

enum PartnerApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProfileVisibility {
  PUBLIC
  CONNECTIONS
}

enum ChatContext {
  LISTING
  JOB_APPLICATION
  NETWORK_DM
  ADMIN_DM
}

enum MessageKind {
  TEXT
  OFFER
  VISIT
  ATTACHMENT
  SYSTEM
}

enum NotificationKind {
  LISTING_APPROVED
  MESSAGE
  OFFER
  JOB_APPLIED
  CONNECTION_REQ
  ENDORSEMENT
  ADMIN
  MENTION
  TEST_ASSIGNED
  INTERVIEW_SCHEDULED
  INTERVIEW_REMINDER
  SCORECARD_REQUESTED
  ADMIN_BROADCAST
  ADMIN_DM
  BAN_NOTICE
  DATA_EXPORT_READY
  JOB_RECOMMENDED
  INVITE_TO_APPLY
  SAVED_SEARCH_DIGEST
}

enum TestKind {
  MCQ
  CODING
  FREE_TEXT
  VIDEO
  FILE_UPLOAD
  MIXED
}

enum AssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  SUBMITTED
  PENDING_GRADE
  EXPIRED
  GRADED
}

enum SavedSearchFrequency {
  DAILY
  WEEKLY
  OFF
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum HiringTeamRole {
  RECRUITER
  HIRING_MANAGER
  INTERVIEWER
  OBSERVER
}

enum EmailTemplateKind {
  INTERVIEW_INVITE
  REJECT
  OFFER
  ASSESSMENT_INVITE
  CUSTOM
}

enum EmailSendStatus {
  SENT
  FAILED
  MOCKED
}

enum EmailSendProvider {
  RESEND
  CONSOLE
}

// ─── Core ────────────────────────────────────────────────────────────────────

model User {
  id                 String             @id @default(cuid())
  phone              String?            @unique
  email              String?            @unique
  emailVerified      DateTime?
  name               String?
  cnHash             String?            @unique
  role               Role               @default(USER)
  isPhoneVerified    Boolean            @default(false)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  docType            IdentityDocType?
  isPartner          Boolean            @default(false)
  partnerType        PartnerType?
  defaultRegionId    String?
  languagePref       String             @default("en")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  defaultRegion       Region?             @relation("UserDefaultRegion", fields: [defaultRegionId], references: [id])
  sellerProfile       SellerProfile?
  employerProfile     EmployerProfile?
  jobSeekerProfile    JobSeekerProfile?
  networkProfile      NetworkProfile?
  sentMessages        Message[]           @relation("SentMessages")
  notifications       Notification[]
  adminActions        AdminActionLog[]    @relation("AdminActions")
  escrowAsBuyer       EscrowTransaction[] @relation("EscrowBuyer")
  escrowAsSeller      EscrowTransaction[] @relation("EscrowSeller")
  listingReviews      ListingReview[]     @relation("ReviewAuthor")
  ownedCompanies      Company[]           @relation("CompanyOwner")
  postedJobPostings   JobPosting[]        @relation("JobPostingPoster")
  postLikes           PostLike[]
  postComments        PostComment[]
  connectionsAsRequester Connection[]    @relation("ConnectionRequester")
  connectionsAsRecipient Connection[]    @relation("ConnectionRecipient")
  chatRoomsAsA        ChatRoom[]          @relation("ChatParticipantA")
  chatRoomsAsB        ChatRoom[]          @relation("ChatParticipantB")
  accounts                Account[]
  sessions                Session[]
  partnerApplication      PartnerApplication?
  hiringTeamMemberships   HiringTeam[]
  candidateNotes          CandidateNote[]     @relation("NoteAuthor")
  testAssignmentsGiven    TestAssignment[]    @relation("TestAssignedBy")
  savedSearches           SavedSearch[]
  searchClicks            SearchClickLog[]
  sentInvites             InviteToApply[]     @relation("InviteSender")
  receivedInvites         InviteToApply[]     @relation("InviteCandidate")
  doNotContact            CandidateDoNotContact?
}

model Region {
  id       String   @id @default(cuid())
  name     String
  nameUr   String
  city     String
  country  String   @default("PK")
  slug     String   @unique
  parentId String?
  lat      Float?
  lng      Float?

  parent      Region?   @relation("RegionChildren", fields: [parentId], references: [id])
  children    Region[]  @relation("RegionChildren")
  users       User[]    @relation("UserDefaultRegion")
  listings    Listing[]
  jobPostings JobPosting[]
  companies   Company[]
}

model OtpCode {
  id          String    @id @default(cuid())
  phone       String
  codeHash    String
  expiresAt   DateTime
  attempts    Int       @default(0)
  consumedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([phone, createdAt])
}

model ChatRoom {
  id             String      @id @default(cuid())
  contextType    ChatContext
  contextId      String
  participantAId String
  participantBId String
  createdAt      DateTime    @default(now())

  participantA User      @relation("ChatParticipantA", fields: [participantAId], references: [id])
  participantB User      @relation("ChatParticipantB", fields: [participantBId], references: [id])
  messages     Message[]

  @@unique([contextType, contextId, participantAId, participantBId])
}

model Message {
  id        String      @id @default(cuid())
  roomId    String
  senderId  String
  body      String
  kind      MessageKind @default(TEXT)
  metadata  Json?
  createdAt DateTime    @default(now())

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([roomId, createdAt])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String
  targetType String
  targetId   String
  reason     String?
  createdAt  DateTime @default(now())

  admin User @relation("AdminActions", fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([targetType, targetId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  kind      NotificationKind
  payload   Json
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

// ─── Marketplace ─────────────────────────────────────────────────────────────

model SellerProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  agentTier    AgentTier @default(NONE)
  bio          String?
  areasServed  Json?

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listings Listing[]
}

model Listing {
  id                String        @id @default(cuid())
  sellerProfileId   String
  category          String
  title             String
  description       String
  price             Decimal
  currency          String        @default("PKR")
  regionId          String
  lat               Float?
  lng               Float?
  status            ListingStatus @default(DRAFT)
  featured          Boolean       @default(false)
  expiresAt         DateTime?
  propertyType      PropertyType?
  beds              Int?
  baths             Int?
  areaValue         Float?
  areaUnit          String?
  fbrValuationMin   Decimal?
  fbrValuationMax   Decimal?
  videoUrl          String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  searchVector      Unsupported("tsvector")?

  sellerProfile      SellerProfile       @relation(fields: [sellerProfileId], references: [id], onDelete: Cascade)
  region             Region              @relation(fields: [regionId], references: [id])
  images             ListingImage[]
  escrowTransactions EscrowTransaction[]
  reviews            ListingReview[]

  @@index([status, regionId, createdAt])
  @@index([status, featured])
}

model ListingImage {
  id        String @id @default(cuid())
  listingId String
  url       String
  order     Int
  width     Int
  height    Int

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model EscrowTransaction {
  id          String       @id @default(cuid())
  listingId   String
  buyerId     String
  sellerId    String
  amount      Decimal
  currency    String       @default("PKR")
  status      EscrowStatus @default(HELD)
  createdAt   DateTime     @default(now())
  releasedAt  DateTime?
  refundedAt  DateTime?

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer   User    @relation("EscrowBuyer", fields: [buyerId], references: [id])
  seller  User    @relation("EscrowSeller", fields: [sellerId], references: [id])
}

model ListingReview {
  id        String   @id @default(cuid())
  listingId String
  authorId  String
  rating    Int
  body      String?
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  author  User    @relation("ReviewAuthor", fields: [authorId], references: [id])

  @@unique([listingId, authorId])
}

// ─── Jobs ────────────────────────────────────────────────────────────────────

model Company {
  id               String   @id @default(cuid())
  ownerId          String
  name             String
  industry         String?
  size             String?
  websiteUrl       String?
  logoUrl          String?
  regionId         String
  verifiedEmployer Boolean  @default(false)
  createdAt        DateTime @default(now())
  searchVector     Unsupported("tsvector")?

  owner            User              @relation("CompanyOwner", fields: [ownerId], references: [id])
  region           Region            @relation(fields: [regionId], references: [id])
  employerProfiles EmployerProfile[]
  jobPostings      JobPosting[]
  pipelineStages   PipelineStage[]
  candidateTags    CandidateTag[]
  emailTemplates   EmailTemplate[]
  testTemplates    TestTemplate[]
  invitesSent      InviteToApply[]
}

model EmployerProfile {
  id            String  @id @default(cuid())
  userId        String  @unique
  companyId     String
  roleAtCompany String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model JobSeekerProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  headline           String?
  summary            String?
  currentRoleTitle   String?
  openToWork         Boolean  @default(true)
  resumeUrl          String?
  expectedSalaryMin  Int?
  expectedSalaryMax  Int?
  currency           String?

  recruiterDiscoverable    Boolean    @default(false)
  preferredRemoteType      RemoteType?
  preferredRegionIds       Json       @default("[]")
  doNotRecommendCompanyIds Json       @default("[]")

  user            User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications    Application[]       @relation("JobSeekerApplications")
  jobAlerts       JobAlert[]
  resumeParsed    ResumeParsed?
  recommendations JobRecommendation[]
}

model ResumeParsed {
  id                 String   @id @default(cuid())
  jobSeekerProfileId String   @unique
  source             String   @default("UPLOAD")
  rawText            String
  extracted          Json?
  parsedAt           DateTime @default(now())

  jobSeekerProfile JobSeekerProfile @relation(fields: [jobSeekerProfileId], references: [id], onDelete: Cascade)
}

model JobPosting {
  id                String     @id @default(cuid())
  companyId         String
  postedByUserId    String
  title             String
  description       String
  regionId          String
  remoteType        RemoteType @default(ONSITE)
  salaryMin         Int?
  salaryMax         Int?
  currency          String     @default("PKR")
  status            JobStatus  @default(DRAFT)
  expiresAt         DateTime?
  requiredSkills    Json       @default("[]")
  niceToHaveSkills  Json       @default("[]")
  requiredKeywords  Json       @default("[]")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  searchVector      Unsupported("tsvector")?

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  postedBy         User              @relation("JobPostingPoster", fields: [postedByUserId], references: [id])
  region           Region            @relation(fields: [regionId], references: [id])
  applications     Application[]
  hiringTeam       HiringTeam[]
  candidateMatches CandidateMatch[]
  recommendations  JobRecommendation[]
  invites          InviteToApply[]

  @@index([status, regionId, createdAt])
  @@index([companyId, status])
}

model Application {
  id              String            @id @default(cuid())
  jobPostingId    String
  jobSeekerId     String
  applicantUserId String?
  resumeUrl       String
  coverLetter     String?
  status          ApplicationStatus @default(APPLIED)
  currentStageId  String?
  createdAt       DateTime          @default(now())

  jobPosting       JobPosting       @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  jobSeeker        JobSeekerProfile @relation("JobSeekerApplications", fields: [jobSeekerId], references: [id], onDelete: Cascade)
  currentStage     PipelineStage?   @relation("ApplicationStage", fields: [currentStageId], references: [id])
  notes            CandidateNote[]
  applicationTags  ApplicationTag[]
  emailsSent       EmailSendLog[]
  candidateMatch   CandidateMatch?
  testAssignments  TestAssignment[]

  @@unique([jobPostingId, jobSeekerId])
}

model CandidateMatch {
  id                 String   @id @default(cuid())
  jobPostingId       String
  applicationId      String   @unique
  score              Int
  requiredMatched    Int
  requiredTotal      Int
  niceToHaveMatched  Int
  niceToHaveTotal    Int
  keywordMatched     Int
  keywordTotal       Int
  matchedTerms       Json
  missedTerms        Json
  computedAt         DateTime @default(now())

  jobPosting  JobPosting  @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([jobPostingId, applicationId])
  @@index([jobPostingId, score])
}

model JobAlert {
  id          String   @id @default(cuid())
  jobSeekerId String
  queryJson   Json
  frequency   String   @default("daily")
  createdAt   DateTime @default(now())

  jobSeeker JobSeekerProfile @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
}

model PipelineStage {
  id         String   @id @default(cuid())
  companyId  String
  name       String
  order      Int
  color      String   @default("#6B7280")
  isInitial  Boolean  @default(false)
  isHired    Boolean  @default(false)
  isRejected Boolean  @default(false)
  createdAt  DateTime @default(now())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications Application[] @relation("ApplicationStage")

  @@unique([companyId, order])
  @@index([companyId])
}

model HiringTeam {
  id           String         @id @default(cuid())
  jobPostingId String
  userId       String
  role         HiringTeamRole
  addedAt      DateTime       @default(now())

  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jobPostingId, userId])
  @@index([jobPostingId])
}

model CandidateNote {
  id            String   @id @default(cuid())
  applicationId String
  authorId      String
  body          String
  mentions      Json?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  author      User        @relation("NoteAuthor", fields: [authorId], references: [id])

  @@index([applicationId, createdAt])
}

model CandidateTag {
  id        String @id @default(cuid())
  companyId String
  name      String
  color     String @default("#6B7280")

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applicationTags ApplicationTag[]

  @@unique([companyId, name])
}

model ApplicationTag {
  id            String @id @default(cuid())
  applicationId String
  tagId         String

  application Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  tag         CandidateTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([applicationId, tagId])
}

model EmailTemplate {
  id        String            @id @default(cuid())
  companyId String
  name      String
  subject   String
  body      String
  kind      EmailTemplateKind @default(CUSTOM)
  createdAt DateTime          @default(now())

  company  Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sendLogs EmailSendLog[]
}

model EmailSendLog {
  id            String            @id @default(cuid())
  applicationId String?
  templateId    String?
  sentByUserId  String
  toEmail       String
  subject       String
  body          String
  status        EmailSendStatus
  provider      EmailSendProvider
  sentAt        DateTime          @default(now())

  application Application?   @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  template    EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([applicationId])
  @@index([sentAt])
}

// ─── Network ─────────────────────────────────────────────────────────────────

model NetworkProfile {
  id                   String            @id @default(cuid())
  userId               String            @unique
  handle               String            @unique
  headline             String?
  summary              String?
  currentRole          String?
  location             String?
  profilePhotoUrl      String?
  bannerUrl            String?
  visibility           ProfileVisibility @default(PUBLIC)
  verifiedProfessional Boolean           @default(false)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  searchVector         Unsupported("tsvector")?

  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  experiences          Experience[]
  educations           Education[]
  profileSkills        ProfileSkill[]
  posts                Post[]
  endorsementsGiven    Endorsement[]  @relation("EndorsementGiver")
  endorsementsReceived Endorsement[]  @relation("EndorsementReceiver")
}

model Experience {
  id          String    @id @default(cuid())
  profileId   String
  company     String
  title       String
  start       DateTime
  end         DateTime?
  description String?

  profile NetworkProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Education {
  id          String    @id @default(cuid())
  profileId   String
  institution String
  degree      String?
  start       DateTime
  end         DateTime?

  profile NetworkProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Skill {
  id   String @id @default(cuid())
  name String @unique

  profileSkills ProfileSkill[]
  endorsements  Endorsement[]
}

model ProfileSkill {
  id        String @id @default(cuid())
  profileId String
  skillId   String

  profile NetworkProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill          @relation(fields: [skillId], references: [id])

  @@unique([profileId, skillId])
}

model Endorsement {
  id                String   @id @default(cuid())
  giverProfileId    String
  receiverProfileId String
  skillId           String
  createdAt         DateTime @default(now())

  giverProfile    NetworkProfile @relation("EndorsementGiver", fields: [giverProfileId], references: [id], onDelete: Cascade)
  receiverProfile NetworkProfile @relation("EndorsementReceiver", fields: [receiverProfileId], references: [id], onDelete: Cascade)
  skill           Skill          @relation(fields: [skillId], references: [id])

  @@unique([giverProfileId, receiverProfileId, skillId])
}

model Connection {
  id          String           @id @default(cuid())
  requesterId String
  recipientId String
  status      ConnectionStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  acceptedAt  DateTime?

  requester User @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient User @relation("ConnectionRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  // INVARIANT: before inserting, check both (A,B) and (B,A) directions don't exist.
  // Use src/core/network/connectionGuard.ts — DB-level bidirectional uniqueness
  // cannot be expressed in Prisma schema DSL and is enforced at the application layer.
  @@unique([requesterId, recipientId])
}

model Post {
  id              String   @id @default(cuid())
  authorProfileId String
  body            String
  mediaUrls       Json?
  createdAt       DateTime @default(now())

  authorProfile NetworkProfile @relation(fields: [authorProfileId], references: [id], onDelete: Cascade)
  likes         PostLike[]
  comments      PostComment[]

  @@index([authorProfileId, createdAt])
}

model PostLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

// ─── NextAuth Adapter ─────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Partner ──────────────────────────────────────────────────────────────────

model PartnerApplication {
  id           String                   @id @default(cuid())
  userId       String                   @unique
  partnerType  PartnerType
  businessName String?
  website      String?
  description  String
  status       PartnerApplicationStatus @default(PENDING)
  reviewedAt   DateTime?
  reviewedById String?
  reason       String?
  createdAt    DateTime                 @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Assessments ─────────────────────────────────────────────────────────────

model TestTemplate {
  id                  String   @id @default(cuid())
  companyId           String
  name                String
  description         String?
  kind                TestKind @default(MCQ)
  durationMin         Int
  passingScorePercent Int?
  isPublished         Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  questions   TestQuestion[]
  assignments TestAssignment[]

  @@index([companyId, isPublished])
}

model TestQuestion {
  id         String   @id @default(cuid())
  templateId String
  order      Int
  kind       TestKind @default(MCQ)
  body       String
  points     Int      @default(1)
  metadata   Json

  template    TestTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  submissions TestSubmission[]

  @@index([templateId, order])
}

model TestAssignment {
  id               String           @id @default(cuid())
  applicationId    String
  templateId       String
  assignedByUserId String
  dueAt            DateTime
  status           AssignmentStatus @default(ASSIGNED)
  startedAt        DateTime?
  submittedAt      DateTime?
  scorePercent     Float?
  autoGraded       Boolean          @default(false)
  createdAt        DateTime         @default(now())

  application Application       @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  template    TestTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  assignedBy  User              @relation("TestAssignedBy", fields: [assignedByUserId], references: [id])
  submissions TestSubmission[]
  session     TestSession?

  @@index([applicationId, status])
}

model TestSubmission {
  id             String    @id @default(cuid())
  assignmentId   String
  questionId     String
  answer         Json
  autoScore      Float?
  manualScore    Float?
  graderNotes    String?
  gradedByUserId String?
  gradedAt       DateTime?

  assignment TestAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  question   TestQuestion   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, questionId])
}

model TestSession {
  id              String   @id @default(cuid())
  assignmentId    String   @unique
  startedAt       DateTime @default(now())
  endsAt          DateTime
  focusLossCount  Int      @default(0)
  fullscreenExits Int      @default(0)
  ipAddress       String?
  userAgent       String?

  assignment TestAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
}

// ─── Phase 26: Saved Searches + Click Logging ─────────────────────────────────

model SavedSearch {
  id         String               @id @default(cuid())
  userId     String
  vertical   String
  name       String
  queryJson  Json
  frequency  SavedSearchFrequency @default(OFF)
  lastSentAt DateTime?
  createdAt  DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([frequency, lastSentAt])
}

model SearchClickLog {
  id          String   @id @default(cuid())
  userId      String?
  query       String
  vertical    String
  clickedId   String
  clickedType String
  position    Int
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clickedId, createdAt])
  @@index([userId, createdAt])
}

// ─── Phase 27: Job Recommendations ───────────────────────────────────────────

model JobRecommendation {
  id           String    @id @default(cuid())
  jobSeekerId  String
  jobPostingId String
  score        Float
  reasons      Json
  sentAt       DateTime?
  createdAt    DateTime  @default(now())

  jobSeeker  JobSeekerProfile @relation(fields: [jobSeekerId], references: [id], onDelete: Cascade)
  jobPosting JobPosting       @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)

  @@unique([jobSeekerId, jobPostingId])
  @@index([jobSeekerId])
}

// ─── Phase 28: Invite to Apply ───────────────────────────────────────────────

model InviteToApply {
  id              String       @id @default(cuid())
  companyId       String
  jobPostingId    String
  senderUserId    String
  candidateUserId String
  message         String?
  status          InviteStatus @default(PENDING)
  sentAt          DateTime     @default(now())
  respondedAt     DateTime?
  expiresAt       DateTime

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobPosting JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  sender     User       @relation("InviteSender", fields: [senderUserId], references: [id])
  candidate  User       @relation("InviteCandidate", fields: [candidateUserId], references: [id])

  @@unique([jobPostingId, candidateUserId])
  @@index([candidateUserId, status, sentAt])
  @@index([companyId, sentAt])
}

model CandidateDoNotContact {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
