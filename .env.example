# ─── Storage mode ────────────────────────────────────────────────────────────
# Use "local" for development (files saved to ./uploads/)
# Use "s3"    for production (Supabase S3)
STORAGE_MODE="s3"

# ─── Database (Supabase Postgres) ────────────────────────────────────────────
# Use the POOLER connection string for runtime (DATABASE_URL)
# Use the DIRECT connection string for Prisma migrations (DIRECT_URL)
DATABASE_URL="postgresql://postgres.YOURPROJECTID:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOURPROJECTID:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="https://app.xplosale.com"
# Session lifetime in days (default: 30)
SESSION_MAX_AGE_DAYS="30"

# ─── Admin bootstrap ─────────────────────────────────────────────────────────
# The first sign-in from this email is auto-promoted to ADMIN (only if no admin exists yet).
# Comment out after initial setup.
ADMIN_EMAIL="your-admin@example.com"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorised redirect URI: https://app.xplosale.com/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Email ────────────────────────────────────────────────────────────────────
# EMAIL_SERVER activates the NextAuth magic-link (Nodemailer) provider.
# RESEND_API_KEY activates transactional mail (OTP notifications, alerts).
# Both are optional; omit to disable their respective features.
EMAIL_SERVER="smtp://user:password@smtp.example.com:587"
EMAIL_FROM="noreply@xplosale.com"
RESEND_API_KEY="re_your-resend-api-key"

# ─── Supabase Storage (S3-compatible) ────────────────────────────────────────
# Find these in Supabase Dashboard → Storage → S3 Access
SUPABASE_S3_ENDPOINT="https://YOURPROJECTID.supabase.co/storage/v1/s3"
SUPABASE_S3_REGION="ap-southeast-1"
SUPABASE_S3_ACCESS_KEY="your-s3-access-key"
SUPABASE_S3_SECRET_KEY="your-s3-secret-key"
SUPABASE_PUBLIC_BUCKET="xplosale-public"
SUPABASE_PRIVATE_BUCKET="xplosale-private"

# ─── Upstash Redis ───────────────────────────────────────────────────────────
# TLS URL from Upstash console — used by Node.js runtime (starts with rediss://)
UPSTASH_REDIS_URL="rediss://default:YOUR-TOKEN@YOUR-ENDPOINT.upstash.io:6379"

# REST API URL + token — used by Edge runtime (middleware) for instant ban checks.
# Find in Upstash console → REST API tab. Optional; omit to fall back to JWT-only ban check.
UPSTASH_REDIS_REST_URL="https://YOUR-ENDPOINT.upstash.io"
UPSTASH_REDIS_REST_TOKEN="YOUR-REST-TOKEN"

# ─── Security ────────────────────────────────────────────────────────────────
# Salt for CNIC hash — never store raw CNIC numbers
# Generate with: openssl rand -base64 32
CNIC_HASH_SALT="generate-with: openssl rand -base64 32"

# ─── Cron jobs ────────────────────────────────────────────────────────────────
# Shared secret for cron endpoints — sent as Bearer token in Authorization header
# Generate with: openssl rand -hex 32
RECOMMENDATION_CRON_SECRET="generate-with: openssl rand -hex 32"

# ─── Search ──────────────────────────────────────────────────────────────────
# How long to cache autocomplete suggestions in Upstash (seconds)
SEARCH_AUTOSUGGEST_CACHE_TTL_SECONDS="300"

# ─── Recommendations ─────────────────────────────────────────────────────────
RECOMMENDATION_BATCH_SIZE="200"
INVITE_TO_APPLY_DAILY_CAP_PER_COMPANY="20"
INVITE_TO_APPLY_MONTHLY_CAP_PER_CANDIDATE="5"

# ─── Analytics ───────────────────────────────────────────────────────────────
# Set to "true" to enable analytics scripts (respects cookie consent)
NEXT_PUBLIC_ANALYTICS_ENABLED="false"

# ─── App ─────────────────────────────────────────────────────────────────────
# Public URL of your deployment (no trailing slash)
NEXT_PUBLIC_APP_URL="https://app.xplosale.com"

# Node environment
NODE_ENV="production"
